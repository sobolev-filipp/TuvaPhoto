{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    // Инкрементальная сборка вместе с deleteOutDir у nest build оставляла
    // кэш, переживший удаление dist: в выход попадал только main.js.
    "incremental": false,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  // Только приложение: prisma/seed.ts и prisma.config.ts исполняет tsx/Prisma CLI,
  // а если включить их сюда, rootDir поднимется и сборка ляжет в dist/src.
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
