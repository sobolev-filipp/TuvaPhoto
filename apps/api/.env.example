# Скопируйте в .env и подставьте свои значения. .env в git не попадает.

# Подключение к Postgres из docker-compose.yml
DATABASE_URL="postgresql://tuvafoto:tuvafoto@127.0.0.1:5432/tuvafoto?schema=public"

PORT=3000
NODE_ENV=development

# Адрес фронта — для CORS и ссылок в письмах
WEB_ORIGIN="http://localhost:5173"

# Секреты JWT. В проде сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="dev-only-change-me-access"
JWT_REFRESH_SECRET="dev-only-change-me-refresh"

# Владелец сайта: аккаунт заводится сидом, регистрации админов нет.
# Это ВРЕМЕННЫЙ пароль первого входа — при первом входе сайт заставит его сменить.
# Первый вход:  логин Tuvafoto@mail.ru  /  пароль TuvaFoto-2026
OWNER_EMAIL="Tuvafoto@mail.ru"
OWNER_NAME="Иванов Александр"
OWNER_PASSWORD="TuvaFoto-2026"

# Версия текста политики — попадает в записи согласий (152-ФЗ)
POLICY_VERSION="2026-07-01"

# Почта (SMTP). Пока SMTP_HOST пустой — код 2FA и ссылка сброса печатаются
# в консоль сервера с пометкой [DEV-EMAIL]. Для боевого сайта заполнить.
# Порт 465 = SSL, 587 = STARTTLS. Пароль — «пароль приложения», не от ящика.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Соцвход. Кнопка провайдера появляется на сайте, только если заданы обе строки.
# Базовый адрес API для сборки redirect_uri коллбэка (в проде — публичный домен).
OAUTH_REDIRECT_BASE="http://localhost:3000/api"
# Яндекс ID: https://oauth.yandex.ru — создать приложение, Callback URI указать
# как ${OAUTH_REDIRECT_BASE}/auth/oauth/yandex/callback
YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""
# VK: https://vk.com/apps?act=manage — Callback ${OAUTH_REDIRECT_BASE}/auth/oauth/vk/callback
VK_CLIENT_ID=""
VK_CLIENT_SECRET=""

# Куда складываются загруженные фото (локальный диск; позже — S3)
STORAGE_DIR="./uploads"
